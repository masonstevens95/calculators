{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @apps/remote build",
  "outputDirectory": "apps/remote/dist",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-ancestors 'self' https://*.substack.com https://substack.com https://*.vercel.app https://masonstevens.dev https://*.masonstevens.dev http://localhost:*"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/remoteEntry.js",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/mf-manifest.json",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/calc/birchwood-rent-sell",
      "destination": "/calc/rent-sell",
      "permanent": true
    },
    {
      "source": "/embed/birchwood-rent-sell",
      "destination": "/embed/rent-sell",
      "permanent": true
    },
    {
      "source": "/calc/surry-county-offer",
      "destination": "/calc/rural-land-offer",
      "permanent": true
    },
    {
      "source": "/embed/surry-county-offer",
      "destination": "/embed/rural-land-offer",
      "permanent": true
    },
    {
      "source": "/calc/lgs-dscr",
      "destination": "/calc/modular-home-dscr",
      "permanent": true
    },
    {
      "source": "/embed/lgs-dscr",
      "destination": "/embed/modular-home-dscr",
      "permanent": true
    },
    {
      "source": "/calc/olamina-dscr",
      "destination": "/calc/modular-home-dscr",
      "permanent": true
    },
    {
      "source": "/embed/olamina-dscr",
      "destination": "/embed/modular-home-dscr",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/:path*", "destination": "/index.html" }]
}
